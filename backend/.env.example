# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# At minimum, fill in ONE of the API key sections below.

# ── LLM Providers ──────────────────────────────────────────────────────────────
# OpenAI (recommended: gpt-5-mini)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini

# OpenRouter (gives access to Claude, Gemini, Llama, and more)
OPENROUTER_API_KEY=

# Google Gemini (direct API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Default model used for tailoring (can be changed in Settings UI)
# Examples: gpt-5-mini | anthropic/claude-sonnet-4-5 | gemini-2.5-flash
DEFAULT_MODEL=gpt-5-mini

# ── App Settings ───────────────────────────────────────────────────────────────
PROJECT_NAME="ResuMate Career OS"
API_V1_STR="/api/v1"

# Public URL of this app (used as HTTP-Referer for OpenRouter)
# Change this if you expose ResuMate on a domain.
APP_URL=http://localhost:1235

# ── Docker / Data Paths (set automatically by docker-compose.yml) ──────────────
# Only set these manually if you are running outside Docker.

# Absolute path to the project root (where data/ and my_info/ live)
# APP_ROOT=/app

# SQLite database URL (absolute path required in Docker)
# DATABASE_URL=sqlite+aiosqlite:////app/data/resumate.db
